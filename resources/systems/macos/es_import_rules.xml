<?xml version="1.0"?>
<!-- This is the ES-DE import rules configuration file for macOS -->
<ruleList>
    <system name="desktop">
        <rule type="macosbundle">
            <directory recursive="false">/Applications</directory>
        </rule>
    </system>
    <system name="emulators">
        <rule type="macosbundle">
            <directory recursive="false">/Applications</directory>
        </rule>
    </system>
</ruleList>